# App
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/opentrails.db
CORS_ORIGINS=http://localhost:8000
RATE_LIMIT_PER_MINUTE=120
CACHE_TTL_SECONDS=900
